# =====================================================================
# BetAnalytics Pro — Variáveis de ambiente (exemplo)
# ---------------------------------------------------------------------
# Copie este arquivo para `.env.local` (ignorado pelo git) e preencha
# os valores abaixo. NUNCA versione `.env` ou `.env.local` no GitHub.
#
# Para gerar automaticamente: `npm run setup:env`
# =====================================================================

# URL pública do projeto Supabase (Lovable Cloud)
# Ex.: https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Chave PUBLISHABLE (anon) do Supabase — segura para frontend
# Encontre em: Lovable Cloud → Settings → API Keys (publishable)
VITE_SUPABASE_PUBLISHABLE_KEY=

# ID do projeto Supabase (parte do subdomínio da URL)
# Ex.: pvreimxxppnyaykveiib
VITE_SUPABASE_PROJECT_ID=
